#!/usr/bin/env sh
# Thin wrapper so you don't type the docker boilerplate.
#
#   ./brainiac up                     # start the stack
#   ./brainiac import                 # ingest Markdown from ./data/docs
#   ./brainiac search "why kafka"
#   ./brainiac recall "why is X like this"
#   ./brainiac health
#   ./brainiac update                 # health-gated update to the latest release (rolls back on failure)
#   ./brainiac down | logs
#   ./brainiac mcp-config             # print the Claude Desktop MCP config
#   ./brainiac instructions           # print the agent memory instruction block
#
# Everything else is passed straight to the in-container `kb` CLI.
set -e
cd "$(dirname "$0")"

case "${1:-}" in
	up)    shift; exec docker compose up -d "$@" ;;
	down)  shift; exec docker compose down "$@" ;;
	logs)  shift; exec docker compose logs -f "$@" ;;
	update)
		# One-command, health-gated update to the latest release tag, with
		# rollback (#160). Updates to release tags only ‚Äî never auto-deploys main.
		# Data is safe: named volumes are untouched; migrations auto-apply on boot.
		url="${BRAINIAC_URL:-http://127.0.0.1:${HTTP_PORT:-8080}}"
		if [ -n "$(git status --porcelain)" ]; then
			echo "update: working tree has local changes ‚Äî commit or stash them first." >&2
			exit 1
		fi
		echo "update: fetching tags‚Ä¶"
		git fetch --tags --quiet
		latest="$(git tag --sort=-v:refname | grep -E '^v[0-9]+\.[0-9]+\.[0-9]+$' | head -1)"
		if [ -z "$latest" ]; then
			echo "update: no release tags found." >&2
			exit 1
		fi
		before="$(git rev-parse HEAD)"
		current="$(git describe --tags --exact-match 2>/dev/null || true)"
		if [ "$current" = "$latest" ]; then
			echo "update: already up to date ($latest)."
			exit 0
		fi
		echo "update: ${current:-$before} ‚Üí $latest ‚Äî rebuilding‚Ä¶"
		git checkout --quiet "$latest"
		if ! docker compose up -d --build; then
			echo "update: build failed ‚Äî rolling back to ${current:-$before}‚Ä¶" >&2
			git checkout --quiet "$before"
			docker compose up -d --build || true
			exit 1
		fi
		# Gate on the app container's OWN Docker health status ‚Äî the same check
		# that marks it "healthy" ‚Äî instead of a fixed curl/readyz window. During
		# the coordinated recreate the container sits in "starting" (not
		# "unhealthy") until its healthcheck first passes, so a slow first boot no
		# longer trips a false rollback. Falls back to curl /readyz only if the
		# app has no healthcheck defined.
		echo "update: waiting for the app container to become healthy‚Ä¶"
		ok=0
		i=0
		while [ "$i" -lt 90 ]; do
			cid="$(docker compose ps -q app 2>/dev/null)"
			if [ -n "$cid" ]; then
				health="$(docker inspect --format '{{if .State.Health}}{{.State.Health.Status}}{{else}}none{{end}}' "$cid" 2>/dev/null || echo "")"
				case "$health" in
					healthy) ok=1; break ;;
					unhealthy) break ;;  # definitively bad ‚Äî stop waiting, roll back now
					none)  # no healthcheck on app ‚Äî fall back to curl /readyz
						if command -v curl >/dev/null 2>&1 && curl -fsS "$url/readyz" >/dev/null 2>&1; then ok=1; break; fi ;;
				esac
			fi
			i=$((i + 1))
			sleep 2
		done
		if [ "$ok" -ne 1 ]; then
			echo "update: $latest did not become healthy in time ‚Äî rolling back to ${current:-$before}‚Ä¶" >&2
			git checkout --quiet "$before"
			docker compose up -d --build || true
			echo "update: rolled back. Check 'brainiac logs app'." >&2
			exit 1
		fi
		echo "update: now on $latest ‚úì"
		exit 0
		;;
	mcp-config)
		printf '{\n  "mcpServers": {\n    "brainiac": {\n      "command": "docker",\n      "args": ["compose","-f","%s/docker-compose.yml","exec","-T","app","/brainiac-mcp"]\n    }\n  }\n}\n' "$(pwd)"
		;;
	instructions)
		# The agent memory instruction block ‚Äî paste into any agent's system
		# prompt / rules (global or per-project). See docs/agent-memory.md.
		cat <<'EOF'
You have a persistent memory provided by the `brainiac` MCP server. Treat it as
your long-term memory, shared across all sessions.

Before answering anything non-trivial (how or why something works, a decision, a
fact about our systems, projects, or past choices), first call `recall` (or
`search`) to check what is already known, and ground your answer in it ‚Äî cite the
source_uri of each claim. If nothing relevant is found, say so briefly, then answer.
When you're working within a project, pass its name as `project` to `recall`/`search`
so results focus on that project plus universal facts; omit it to look across everything.

Whenever we learn or decide something worth keeping ‚Äî a finding from a document, a
conclusion from our discussion, a decision and its rationale, "X works like Y",
"we chose A over B because C" ‚Äî save it proactively, without being asked:
- `remember` the entities involved (canonical name, type, a short summary), and set
  `project` to the project you're working in (its repo/workspace name) so same-named
  entities in different projects stay distinct. Omit `project` for universal facts
  (a vendor, a standard, a shared tool) ‚Äî those are global.
- `link` the relationships, always filling in `why`, set source_uri/author when
  known, and pass the same `project` as the entities.
- Prefer consistent, snake_case types so relationships stay comparable and
  contradictions are detectable: entities like `service`, `datastore`, `decision`,
  `constraint`, `team`, `person`; relationships like `writes_to`, `depends_on`,
  `rejected`, `supersedes`. Reuse an existing type instead of inventing a synonym.
  (Case and separators are normalized ‚Äî `writes-to`, `writesTo` fold into
  `writes_to` ‚Äî but a synonym like `publishes_to` stays a distinct type.)
- For a document or passage that should be findable verbatim later (e.g. a page
  you read via your own integration), call `add_document` with a stable source_uri
  and the text.
- If a previous decision changed, call `supersede` ‚Äî never delete; keep the history.
- If you realize an entity you saved actually conflates two things (e.g. the prod vs
  the staging one), call `disambiguate` on it with the axis that separates them
  (e.g. `env=prod`); the other variant then becomes a distinct entity. Introduce such
  axes only when you actually see a conflation ‚Äî don't over-tag up front.

Save decisions, rationale, and non-obvious findings; skip small talk and trivia.
Keep entity names canonical and consistent so duplicates merge. When unsure whether
something is already stored, `recall` first to avoid duplicates. At the end of a
substantive session, briefly list what you saved.
EOF
		;;
	import)
		# `import` with no extra args defaults to the mounted markdown folder.
		if [ "$#" -eq 1 ]; then
			exec docker compose exec app /kb import --source markdown --path /data/docs
		fi
		exec docker compose exec app /kb "$@"
		;;
	"")    exec docker compose exec app /kb ;;
	*)     exec docker compose exec app /kb "$@" ;;
esac
