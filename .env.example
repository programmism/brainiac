# Copy to .env and edit. These power docker-compose.yml.
# The app reads DATABASE_URL/OLLAMA_URL/HTTP_ADDR from the environment (compose
# builds DATABASE_URL from the POSTGRES_* values below).

POSTGRES_USER=brainiac
POSTGRES_PASSWORD=brainiac
POSTGRES_DB=brainiac

# Host port the app is published on.
HTTP_PORT=8080

# Embedding model pulled into Ollama on first boot.
EMBEDDING_MODEL=nomic-embed-text

# Optional local-LLM extractor (off by default — the chat-driven path needs no
# extra model). Turn it on ONLY if your box can run a chat model: it derives
# graph nodes/edges from ingested text via Ollama structured outputs. Extracted
# rows go to a review queue (WebUI Proposals tab) until approved.
#   EXTRACTOR=local-llm          # enable it (default: chat-driven = off)
#   EXTRACTION_MODEL=llama3.1     # required when enabled; a chat model in Ollama
#   EXTRACTION_URL=               # defaults to the embedding Ollama URL
#   EXTRACTION_REVIEW=true        # false = write extracted rows live (skip review)

# Auto-import: re-scan ./data/docs on this interval (empty = off). Great for laptops.
INGEST_INTERVAL=60s

# Notion integration token for `kb import --source notion` (optional).
# NOTION_TOKEN=secret_xxx

# Slack bot token for `kb import --source slack` (optional). Needs channels:read
# and channels:history scopes; the bot must be a member of the channels to read.
# SLACK_TOKEN=xoxb-...

# Anthropic API key for server-side Claude extraction (optional; set
# EXTRACTOR=claude to enable — derives nodes/edges from chunks during ingest, #235).
# ANTHROPIC_API_KEY=sk-ant-...

# WebUI write actions (merge / retire / approve proposals) are DISABLED by
# default (secure). To enable, set BOTH of these, then paste the same token into
# the WebUI's token field:
# WEBUI_MODE=interactive
# AUTH_TOKEN=change-me-long-random

# Layer 2 hard isolation (#120) — one server, many namespaces, per-token wall.
# Opt-in: define principals in config.yaml, then set each one's bearer token here
# as PRINCIPAL_TOKEN_<NAME> (NAME uppercased, non-alphanumerics -> '_'). When any
# principal is configured, ALL /api reads require a token too. The MCP stdio
# process runs as one principal, chosen by BRAINIAC_PRINCIPAL (needed only when
# more than one is configured).
# PRINCIPAL_TOKEN_TEAM_A=change-me-long-random
# PRINCIPAL_TOKEN_PLATFORM=change-me-long-random
# The MCP stdio process binds to a principal by its SECRET token (not just a
# name), so exec-ing the binary isn't enough to assume a namespace (#266):
# BRAINIAC_PRINCIPAL_TOKEN=change-me-long-random

# Reverse proxy (docker compose --profile proxy up). See Caddyfile.
# SITE_ADDRESS=memory.example.com   # domain (auto-HTTPS), ":443" (+tls internal), or ":80"
# BASIC_AUTH_USER=admin
# BASIC_AUTH_HASH=                    # caddy hash-password --plaintext '…'
