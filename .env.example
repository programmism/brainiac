# Copy to .env and edit. These power docker-compose.yml.
# The app reads DATABASE_URL/OLLAMA_URL/HTTP_ADDR from the environment (compose
# builds DATABASE_URL from the POSTGRES_* values below).
# To use a MANAGED Postgres (RDS/Cloud SQL/Neon) instead of the bundled db, set a
# full TLS DSN here and add the override (#253, see docs/managed-postgres.md):
#   DATABASE_URL=postgres://user:pass@host:5432/brainiac?sslmode=verify-full
#   docker compose -f docker-compose.yml -f docker-compose.managed.yml up -d

POSTGRES_USER=brainiac
POSTGRES_PASSWORD=brainiac
POSTGRES_DB=brainiac

# Host port the app is published on.
HTTP_PORT=8080

# Embedding model pulled into Ollama on first boot.
EMBEDDING_MODEL=nomic-embed-text

# Optional local-LLM extractor (off by default — the chat-driven path needs no
# extra model). Turn it on ONLY if your box can run a chat model: it derives
# graph nodes/edges from ingested text via Ollama structured outputs. Extracted
# rows go to a review queue (WebUI Proposals tab) until approved.
#   EXTRACTOR=local-llm          # enable it (default: chat-driven = off)
#   EXTRACTION_MODEL=llama3.1     # required when enabled; a chat model in Ollama
#   EXTRACTION_URL=               # defaults to the embedding Ollama URL
#   EXTRACTION_REVIEW=true        # false = write extracted rows live (skip review)

# Auto-import: re-scan ./data/docs on this interval (empty = off). Great for laptops.
INGEST_INTERVAL=60s

# Notion integration token for `kb import --source notion` (optional).
# NOTION_TOKEN=secret_xxx

# Slack bot token for `kb import --source slack` (optional). Needs channels:read
# and channels:history scopes; the bot must be a member of the channels to read.
# SLACK_TOKEN=xoxb-...

# Anthropic API key for server-side Claude extraction (optional; set
# EXTRACTOR=claude to enable — derives nodes/edges from chunks during ingest, #235).
# ANTHROPIC_API_KEY=sk-ant-...

# GitHub token for `kb import --source github` (optional, #238). A PAT with repo
# read scope; imports issues + PRs. Repos from GITHUB_REPOS or sources[].repos.
# GITHUB_TOKEN=ghp_...
# Opt-in (#354): also ingest a repo's tracked files matching these path globs as
# documents (in addition to issues/PRs). Empty = off. Globs: dir/**, *.md, README*.
# GITHUB_FILES=README*,docs/**,*.md,ADR*
# GITHUB_REPOS=owner/repo,owner/other

# Google Drive OAuth access token for `kb import --source gdrive` (optional, #239).
# Imports Google Docs (exported to text) + text files. Minting/refreshing the token
# is out of scope here (see the per-source OAuth store, #246).
# GDRIVE_TOKEN=ya29....

# Linear API key for `kb import --source linear` (optional, #240). Imports Linear
# issues (title + markdown description).
# LINEAR_TOKEN=lin_api_...

# GitLab for `kb import --source gitlab` (optional, #340). Access token with
# read_api scope; imports issues + merge requests (title + markdown description).
# Projects from GITLAB_PROJECTS or sources[].repos; host defaults to gitlab.com.
# GITLAB_TOKEN=glpat-...
# GITLAB_PROJECTS=group/project,group/other
# GITLAB_BASE_URL=https://gitlab.example.com   # self-managed only

# Jira Cloud for `kb import --source jira` (optional, #343). Basic email:token
# auth against a site; imports issues (summary + ADF description → text). Set all
# three together.
# JIRA_BASE_URL=https://your-site.atlassian.net
# JIRA_EMAIL=you@example.com
# JIRA_TOKEN=your-api-token

# Confluence Cloud for `kb import --source confluence` (optional, #343). Basic
# email:token auth; imports pages (title + XHTML storage body → text). Set all
# three together (note the /wiki base).
# CONFLUENCE_BASE_URL=https://your-site.atlassian.net/wiki
# CONFLUENCE_EMAIL=you@example.com
# CONFLUENCE_TOKEN=your-api-token

# Retrieval distance thresholds (optional, #332). Tune relevance gating per
# embedding model/domain without a rebuild; unset = built-in defaults. Cosine
# distance runs 0..2; gaps are >= 0. Chunk gates apply to search, node gates to
# recall.
# RETRIEVAL_MAX_CHUNK_DISTANCE=0.75
# RETRIEVAL_CHUNK_DISTANCE_GAP=0.15
# RETRIEVAL_MAX_NODE_DISTANCE=0.55
# RETRIEVAL_NODE_DISTANCE_GAP=0.10

# HNSW vector-index build params (optional, #233). Defaults match pgvector
# (m=16, ef_construction=64); raise ahead of a large (10M+) tier for better
# recall, then apply with `kb reindex`. ef_construction must be >= 2*m.
# HNSW_M=16
# HNSW_EF_CONSTRUCTION=64

# Hot->cold tiering (optional, #231). If set (a Go duration, e.g. 4320h = 180d),
# `kb sweep-tiers` archives hot chunks older than this to the cold tier to keep
# the hot vector index within RAM. Unset = disabled (tiering stays promote-only).
# TIERING_MAX_HOT_AGE=4320h

# Historical-row retention (optional, #363). If set (a Go duration, e.g. 8760h =
# 1y), `kb sweep-retention` hard-deletes superseded (historical) nodes/edges older
# than this. Current memory is never touched. Unset = keep everything.
# RETENTION_MAX_AGE=8760h

# OCR for scanned / image-only PDFs (optional, #356). OFF by default. When on,
# a PDF with no text layer is OCR'd by shelling out to OCR_COMMAND, invoked as
# `<command> <pdf-file> stdout` (tesseract's CLI; wrap another tool in a script).
# Needs the tool installed on the app image/host. Default: image-only PDFs are
# skipped (empty).
# OCR_ENABLED=true
# OCR_COMMAND=tesseract

# Per-source trust (optional, #361). Remote-connector content is untrusted by
# default (its extraction is forced through review; recall flags it); LOCAL files
# (markdown) are trusted by default since you placed them. Mark a remote source
# you vouch for as trusted with <TYPE>_TRUST=trusted (type: github, gdrive, notion,
# slack, linear, gitlab, jira, confluence). e.g.:
# GITHUB_TRUST=trusted
# MARKDOWN_TRUST=untrusted   # force local files untrusted if you don't vouch for them

# WebUI write actions (merge / retire / approve proposals) are DISABLED by
# default (secure). To enable, set BOTH of these, then paste the same token into
# the WebUI's token field:
# WEBUI_MODE=interactive
# AUTH_TOKEN=change-me-long-random

# Layer 2 hard isolation (#120) — one server, many namespaces, per-token wall.
# Opt-in: define principals in config.yaml, then set each one's bearer token here
# as PRINCIPAL_TOKEN_<NAME> (NAME uppercased, non-alphanumerics -> '_'). When any
# principal is configured, ALL /api reads require a token too. The MCP stdio
# process runs as one principal, chosen by BRAINIAC_PRINCIPAL (needed only when
# more than one is configured).
# PRINCIPAL_TOKEN_TEAM_A=change-me-long-random
# PRINCIPAL_TOKEN_PLATFORM=change-me-long-random
# The MCP stdio process binds to a principal by its SECRET token (not just a
# name), so exec-ing the binary isn't enough to assume a namespace (#266):
# BRAINIAC_PRINCIPAL_TOKEN=change-me-long-random

# Reverse proxy (docker compose --profile proxy up). See Caddyfile.
# Require TLS off-box (#271): a domain or :443 — ":80" is LOCAL DEV ONLY (cleartext).
# SITE_ADDRESS=memory.example.com   # domain (auto-HTTPS), or ":443" (+tls internal)
# BASIC_AUTH_USER=admin              # coarse network gate — NOT the tenant boundary;
# BASIC_AUTH_HASH=                    # for multi-team isolation use principals (#120).
#                                     # caddy hash-password --plaintext '…'
