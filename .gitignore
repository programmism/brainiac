# Go
/bin/
*.test
*.out
coverage.txt
# Stray root-level build artifacts: `go build ./cmd/mcp` (etc.) drops a bare
# binary named after the package in the repo root. Official builds go to /bin
# (Makefile) or /out (Docker); these root binaries must never be committed.
/mcp
/http
/cli
/kb
/brainiac-mcp
/brainiac-http

# Python (n/a — kept for tooling that may drop caches)
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
/build/
/dist/
.venv/
venv/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/

# Environment / secrets
.env
*.local
/config.yaml

# Data / volumes (never commit corpus, DB dumps, or model files).
# Root-anchored so they don't shadow source packages (e.g. internal/plugins/ollama).
/data/*
!/data/README.md
/pgdata/
/ollama/
*.dump
*.sql.gz

# Editor / OS
.idea/
.vscode/
.DS_Store

# Backups
/backups/
